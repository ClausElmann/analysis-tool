        "state_machine": {
          "slides": {
            "0": "Email + Password form (default)",
            "1": "2FA — enter SMS/email PIN",
            "2": "2FA — choose delivery method (SMS vs Email)",
            "3": "Password reset — enter email",
            "4": "Password reset — confirmation message",
            "5": "2FA — enter authenticator app code"
          },
          "transitions": [
            "0 → 1: POST /login returns 428 with method=sms or email",
            "0 → 2: POST /login returns 300 (must choose 2FA method)",
            "0 → 5: POST /login returns 428 with authenticatorApp=true",
            "0 → 3: User clicks 'Forgot password'",
            "3 → 4: POST password-reset-request succeeds",
            "Any → 0: Back / Cancel"
          ]
        },
        "title": "Login"
