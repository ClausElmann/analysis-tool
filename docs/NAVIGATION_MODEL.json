  "context_model": {
    "description": "Describes how working context (which customer/profile to operate on) is established per section. This is a LAYOUT-LEVEL concern, not a route concern. It determines what appears in the app shell above the page content.",
    "updated": "2026-04-02",
    "modes": [
      {
        "id": "profile-implicit",
        "applies_to_sections": ["root", "admin"],
        "selector_visible_on_page": false,
        "context_source": "global app-shell profile dropdown",
        "context_params": [],
        "description": "User always operates within their own customer. Profile is selected once in the global shell dropdown and is implicit on all pages. No context selectors appear on individual pages.",
        "blazor_implication": "No context selector component needed on pages in these sections. Profile/customer is read from app state (ICurrentUser or equivalent)."
      },
      {
        "id": "super-admin-explicit",
        "applies_to_sections": ["admin/super"],
        "selector_visible_on_page": true,
        "context_source": "per-page context selector bar",
        "context_params": ["countryId", "customerId", "profileId"],
        "selector_cascade": ["country → customer → profile"],
        "description": "Super-admin operates ON BEHALF of any customer in the system. A context selector bar (country + customer + profile dropdowns) appears at the top of each super-admin page. Changing the selector reloads the page data for the selected context. Profile may be optional on some pages (e.g. customer-level views only need country + customer).",
        "profile_required": "on most pages, but not all — some pages are customer-scoped only (e.g. customers/:id detail)",
        "blazor_implication": "Super-admin layout needs a shared context selector component. Selected context stored in scoped state (e.g. SuperAdminContextState). Pages subscribe/react to context changes."
      }
    ],
    "section_to_mode_map": {
      "root": "profile-implicit",
      "admin": "profile-implicit",
      "admin/super": "super-admin-explicit"
    },
    "deep_link_note": "For super-admin, deep links must encode context in URL: /admin/super/{capability}?countryId=X&customerId=Y&profileId=Z — or use route segments. This enables bookmarkable, shareable super-admin URLs."
  },
